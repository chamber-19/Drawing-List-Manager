{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drawing List Manager",
  "version": "1.0.0",
  "identifier": "com.chamber-19.drawing-list-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splash",
        "url": "splash.html",
        "title": "Drawing List Manager",
        "width": 480,
        "height": 320,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": false
      },
      {
        "label": "main",
        "url": "index.html",
        "title": "Drawing List Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 600,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "ROOT3POWER ENGINEERING",
    "shortDescription": "R3P Drawing List Manager — project drawing register tool",
    "longDescription": "A standalone desktop application for managing project drawing registers at ROOT3POWER ENGINEERING. Supports R3P numbering, revisions, and branded Excel output.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/dlm-backend/**/*",
      "desktop-toolkit-updater.exe"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp",
        "installerHooks": "installer/hooks.nsh",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    }
  }
}
