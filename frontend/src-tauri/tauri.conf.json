{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "R3P Drawing List Manager",
  "version": "1.0.0",
  "identifier": "com.root3power.drawing-list-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "R3P Drawing List Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
